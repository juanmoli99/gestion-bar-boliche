generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  ADMINISTRADOR
  OPERADOR
}

model Usuario {
  id             String     @id @default(uuid())
  nombreCompleto String
  usuario        String     @unique
  email          String?    @unique
  contrasenaHash String
  rol            RolUsuario @default(OPERADOR)
  activo         Boolean    @default(true)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  movimientosStock     MovimientoStock[]
  compras              Compra[]
  reservasCreadas      Reserva[]             @relation("ReservasCreadas")
  reservasActualizadas Reserva[]             @relation("ReservasActualizadas")
  historialReservas    HistorialReserva[]
  calculosCompraFiesta CalculoCompraFiesta[]

  @@map("usuarios")
}

enum TipoInventario {
  BEBIDAS
  COCINA
  LIMPIEZA
  VARIOS
}

enum TipoItem {
  PRODUCTO
  INSUMO
}

enum TipoMovimientoStock {
  ENTRADA
  SALIDA
  AJUSTE_POSITIVO
  AJUSTE_NEGATIVO
}

model Categoria {
  id          String         @id @default(uuid())
  nombre      String
  descripcion String?
  inventario  TipoInventario
  activa      Boolean        @default(true)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  items Item[]

  @@unique([nombre, inventario])
  @@index([inventario])
  @@map("categorias")
}

model UnidadMedida {
  id             String   @id @default(uuid())
  nombre         String   @unique
  abreviatura    String   @unique
  permiteDecimal Boolean  @default(true)
  activa         Boolean  @default(true)
  creadoEn       DateTime @default(now())
  actualizadoEn  DateTime @updatedAt

  items Item[]

  @@map("unidades_medida")
}

model Item {
  id              String   @id @default(uuid())
  nombre          String
  descripcion     String?
  tipo            TipoItem
  categoriaId     String
  unidadMedidaId  String
  unidadesPorPack Int?
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  categoria             Categoria              @relation(fields: [categoriaId], references: [id])
  unidadMedida          UnidadMedida           @relation(fields: [unidadMedidaId], references: [id])
  stocks                Stock[]
  movimientos           MovimientoStock[]
  comprasDetalle        CompraDetalle[]
  formulaVersionItems   FormulaVersionItem[]
  detallesCalculoCompra DetalleCalculoCompra[]
  ultimoCosto           Decimal                @default(0) @db.Decimal(14, 2)
  costoPromedio         Decimal                @default(0) @db.Decimal(14, 2)
  historialCostos       HistorialCostoItem[]

  @@unique([nombre, tipo])
  @@index([categoriaId])
  @@index([unidadMedidaId])
  @@map("items")
}

model Stock {
  id             String         @id @default(uuid())
  itemId         String
  inventario     TipoInventario
  cantidadActual Decimal        @default(0) @db.Decimal(12, 3)
  cantidadMinima Decimal?       @db.Decimal(12, 3)
  creadoEn       DateTime       @default(now())
  actualizadoEn  DateTime       @updatedAt

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, inventario])
  @@index([inventario])
  @@map("stocks")
}

model MovimientoStock {
  id                String              @id @default(uuid())
  itemId            String
  inventario        TipoInventario
  tipo              TipoMovimientoStock
  cantidad          Decimal             @db.Decimal(12, 3)
  cantidadAnterior  Decimal             @db.Decimal(12, 3)
  cantidadPosterior Decimal             @db.Decimal(12, 3)
  motivo            String?
  usuarioId         String?
  creadoEn          DateTime            @default(now())

  item    Item     @relation(fields: [itemId], references: [id])
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([itemId])
  @@index([inventario])
  @@index([creadoEn])
  @@map("movimientos_stock")
}

model Proveedor {
  id String @id @default(uuid())

  razonSocial     String
  nombreComercial String?

  cuit String @unique

  telefono String?
  email    String?

  direccion    String?
  ciudad       String?
  provincia    String?
  codigoPostal String?

  observaciones String?

  activo Boolean @default(true)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt
  compras       Compra[]

  @@map("proveedores")
}

enum EstadoCompra {
  BORRADOR
  CONFIRMADA
  ANULADA
}

model Compra {
  id String @id @default(uuid())

  proveedorId String
  proveedor   Proveedor @relation(fields: [proveedorId], references: [id])

  numeroComprobante String?
  observaciones     String?

  estado EstadoCompra @default(BORRADOR)

  creadoEn      DateTime        @default(now())
  actualizadoEn DateTime        @updatedAt
  usuario       Usuario?        @relation(fields: [usuarioId], references: [id])
  usuarioId     String?
  detalles      CompraDetalle[]
  inventario    TipoInventario

  subtotal Decimal @default(0) @db.Decimal(14, 2)

  descuentoTotal Decimal @default(0) @db.Decimal(14, 2)

  ivaTotal Decimal @default(0) @db.Decimal(14, 2)

  total Decimal @default(0) @db.Decimal(14, 2)

  historialCostos HistorialCostoItem[]

  @@map("compras")
}

model CompraDetalle {
  id String @id @default(uuid())

  compraId String
  compra   Compra @relation(fields: [compraId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  cantidad Decimal @db.Decimal(12, 3)

  precioUnitario Decimal @db.Decimal(12, 2)

  porcentajeDescuento Decimal @default(0) @db.Decimal(5, 2)

  porcentajeIva Decimal @default(21) @db.Decimal(5, 2)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("compras_detalle")
}

enum TipoReserva {
  MESA
  FIESTA
}

enum EstadoReserva {
  PENDIENTE
  SENADA
  CONFIRMADA
  CANCELADA
  FINALIZADA
  ASISTIO
  NO_ASISTIO
}

model Reserva {
  id     String        @id @default(uuid())
  tipo   TipoReserva
  estado EstadoReserva @default(PENDIENTE)

  nombreCliente   String
  telefonoCliente String?

  fechaHora            DateTime
  cantidadPersonas     Int
  cantidadMenusSinTacc Int?

  tipoFiesta String?

  observaciones     String?
  motivoCancelacion String?

  precioTotal    Decimal? @db.Decimal(14, 2)
  montoSena      Decimal? @db.Decimal(14, 2)
  saldoPendiente Decimal? @db.Decimal(14, 2)

  medioPagoSena String?
  fechaSena     DateTime?

  medioPagoFinal String?
  fechaPagoFinal DateTime?

  formulaId        String?
  formulaVersionId String?

  usuarioCreadorId      String?
  usuarioActualizadorId String?

  activa Boolean @default(true)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  formula FormulaCompra? @relation(fields: [formulaId], references: [id])

  formulaVersion FormulaVersion? @relation(fields: [formulaVersionId], references: [id])

  usuarioCreador Usuario? @relation("ReservasCreadas", fields: [usuarioCreadorId], references: [id])

  usuarioActualizador Usuario? @relation("ReservasActualizadas", fields: [usuarioActualizadorId], references: [id])

  historial HistorialReserva[]

  calculosCompra CalculoCompraReserva[]

  detallesCalculo DetalleCalculoCompra[]

  @@index([tipo])
  @@index([estado])
  @@index([formulaId])
  @@index([formulaVersionId])
  @@index([fechaHora])
  @@index([nombreCliente])
  @@map("reservas")
}

model HistorialReserva {
  id            String   @id @default(uuid())
  reservaId     String
  usuarioId     String?
  accion        String
  campo         String?
  valorAnterior String?
  valorNuevo    String?
  creadoEn      DateTime @default(now())

  reserva Reserva  @relation(fields: [reservaId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([reservaId])
  @@index([usuarioId])
  @@index([creadoEn])
  @@map("historial_reservas")
}

enum EstadoCalculoCompra {
  BORRADOR
  CONFIRMADO
  COMPRA_REALIZADA
}

model FormulaCompra {
  id          String  @id @default(uuid())
  nombre      String  @unique
  descripcion String?
  activa      Boolean @default(true)

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  versiones FormulaVersion[]
  reservas  Reserva[]

  @@map("formulas_compra")
}

model FormulaVersion {
  id String @id @default(uuid())

  formulaId     String
  numeroVersion Int

  activa Boolean @default(true)

  creadoEn DateTime @default(now())

  formula FormulaCompra @relation(fields: [formulaId], references: [id], onDelete: Cascade)

  items FormulaVersionItem[]

  reservas Reserva[]

  @@unique([formulaId, numeroVersion])
  @@index([formulaId])
  @@map("formulas_versiones")
}

model FormulaVersionItem {
  id String @id @default(uuid())

  versionId String

  itemId String

  cantidadPorPersona Decimal @db.Decimal(12, 4)

  activo Boolean @default(true)

  creadoEn DateTime @default(now())

  actualizadoEn DateTime @updatedAt

  version FormulaVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  item Item @relation(fields: [itemId], references: [id])

  @@unique([versionId, itemId])
  @@index([versionId])
  @@index([itemId])
  @@map("formulas_versiones_items")
}

model CalculoCompraFiesta {
  id                    String              @id @default(uuid())
  fechaDesde            DateTime
  fechaHasta            DateTime
  estado                EstadoCalculoCompra @default(BORRADOR)
  cantidadPersonasTotal Int                 @default(0)
  observaciones         String?
  usuarioId             String?
  creadoEn              DateTime            @default(now())
  actualizadoEn         DateTime            @updatedAt

  usuario  Usuario?               @relation(fields: [usuarioId], references: [id])
  reservas CalculoCompraReserva[]
  detalles DetalleCalculoCompra[]

  @@index([estado])
  @@index([fechaDesde])
  @@index([fechaHasta])
  @@index([usuarioId])
  @@map("calculos_compra_fiesta")
}

model DetalleCalculoCompra {
  id                     String   @id @default(uuid())
  calculoId              String
  reservaId              String
  itemId                 String
  fecha                  DateTime
  cantidadCalculada      Decimal  @db.Decimal(12, 3)
  cantidadAjustada       Decimal? @db.Decimal(12, 3)
  cantidadPacksCalculada Int?
  creadoEn               DateTime @default(now())
  actualizadoEn          DateTime @updatedAt

  calculo CalculoCompraFiesta @relation(fields: [calculoId], references: [id], onDelete: Cascade)
  reserva Reserva             @relation(fields: [reservaId], references: [id])
  item    Item                @relation(fields: [itemId], references: [id])

  @@unique([calculoId, reservaId, itemId])
  @@index([calculoId])
  @@index([reservaId])
  @@index([itemId])
  @@index([fecha])
  @@map("detalles_calculos_compra")
}

model HistorialCostoItem {
  id String @id @default(uuid())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id])

  compraId String?
  compra   Compra? @relation(fields: [compraId], references: [id])

  costoAnterior Decimal @db.Decimal(14, 2)

  costoNuevo Decimal @db.Decimal(14, 2)

  stockAnterior Decimal @db.Decimal(14, 3)

  stockNuevo Decimal @db.Decimal(14, 3)

  creadoEn DateTime @default(now())

  @@index([itemId])
  @@index([compraId])
  @@map("historial_costos_items")
}

model CalculoCompraReserva {
  id               String   @id @default(uuid())
  calculoId        String
  reservaId        String
  cantidadPersonas Int
  creadoEn         DateTime @default(now())

  calculo CalculoCompraFiesta @relation(fields: [calculoId], references: [id], onDelete: Cascade)
  reserva Reserva             @relation(fields: [reservaId], references: [id], onDelete: Cascade)

  @@unique([calculoId, reservaId])
  @@index([calculoId])
  @@index([reservaId])
  @@map("calculos_compra_reservas")
}
